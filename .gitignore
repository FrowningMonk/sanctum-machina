# ============================================================================
# IDE — IntelliJ IDEA / Android Studio
# ============================================================================
.idea/
*.iml
*.ipr
*.iws

# ============================================================================
# Gradle — build artefacts (per-module and root)
# ============================================================================
build/
**/build/
# Re-include Kotlin source dirs — `**/build/` would otherwise eat any
# package path with a `build` segment (e.g. `…/sanctum/machina/build/`).
!**/src/**
.gradle/
gradle.properties.local

# ============================================================================
# Android — SDK paths, generated outputs, captures, profiling
# ============================================================================
local.properties
captures/
.externalNativeBuild/
.cxx/
.kotlin/
*.apk
*.aab
*.dex
app/release/
app/debug/
hs_err_pid*.log

# ============================================================================
# Room — locally generated schema snapshots (shared schemas live in VCS)
# ============================================================================
app/schemas/*.local.json

# ============================================================================
# Secrets — NEVER commit anything in this section
# ============================================================================
.env
.env.*
!.env.example
*.keystore
*.jks
*.p12
*.pfx
*.key
*.pem
credentials.json
secrets/
release-keys/
keystore.properties
signing.properties

# ============================================================================
# Logs (runtime only — methodology logs under work/*/logs/ ARE tracked)
# ============================================================================
*.log
# Root-level logs/ is a methodology anti-pattern: validator logs must live
# under work/{feature}/logs/, never at repo root. If a run accidentally writes
# to ./logs/ (bare path resolves to CWD), keep it out of VCS.
logs/

# ============================================================================
# OS / Editor cruft
# ============================================================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ============================================================================
# Claude Code — methodology, skills, agents, commands, settings,
# plus CLAUDE.md project instructions. Local-only: the public repo ships
# the project, not the AI tooling around it.
# ============================================================================
.claude/
CLAUDE.md

# ============================================================================
# Vendor — Gallery source snapshot (read-only reference, never committed)
# ============================================================================
gallery-source/

# ============================================================================
# Personal — NOTES.md is the boss's local memo, intentionally out of VCS
# ============================================================================
NOTES.md

# ============================================================================
# Methodology — feature planning artefacts (specs, tasks, decisions, logs).
# Local-only: the public repo ships the project, not the process behind it.
# ============================================================================
work/
