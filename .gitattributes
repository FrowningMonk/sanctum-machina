# Baseline: normalize line endings to LF in the repo, auto-detect text.
* text=auto eol=lf

# Kotlin / Java / Gradle / XML / Markdown — always LF (explicit override for clarity).
*.kt       text eol=lf
*.kts      text eol=lf
*.java     text eol=lf
*.xml      text eol=lf
*.json     text eol=lf
*.toml     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.md       text eol=lf
*.properties text eol=lf
*.pro      text eol=lf
gradlew    text eol=lf

# Windows-only scripts must keep CRLF or cmd.exe refuses to run them.
*.bat      text eol=crlf
*.cmd      text eol=crlf
gradlew.bat text eol=crlf

# Binary assets — never normalize, never diff as text.
*.png      binary
*.jpg      binary
*.jpeg     binary
*.webp     binary
*.gif      binary
*.ico      binary
*.pdf      binary
*.zip      binary
*.jar      binary
*.aar      binary
*.so       binary
*.keystore binary
*.jks      binary
*.p12      binary
*.pfx      binary
*.key      binary
*.pem      binary
*.apk      binary
*.aab      binary
*.dex      binary
# Phase 4 Task 17: .tflite ships in-APK (bundled EmbeddingGemma 300M ~196 MB) — git LFS.
*.tflite   filter=lfs diff=lfs merge=lfs -text
*.task     binary
*.gguf     binary
*.onnx     binary
# Phase 4 Task 17: SentencePiece tokenizer companion to the bundled .tflite (~4.7 MB,
# under GitHub's 100 MB normal-blob ceiling — kept off LFS to preserve bandwidth quota).
*.model    binary
